extends ../components/layouts/base.pug

include ../components/common/breadcrumbs
include ../components/blocks/we-care
include ../components/blocks/awards
include ../components/blocks/prices
include ../components/common/person
include ../components/common/consultation
include ../components/blocks/welcome
include ../components/blocks/counter
include ../components/blocks/comparison
include ../components/blocks/quote
include ../components/blocks/with-love
include ../components/blocks/with-love-2
include ../components/blocks/patients-say
include ../components/blocks/familiar-person

block title
    | Протезирования зубов

block content
    +breadcrumbs(["Главная", "Услуги", "Протезирования зубов"])

    section.banner.section-mb-72
        div.banner__inner.container
            div.banner__text-block.text-center
                h1.banner__title.color-blue Все виды протезирования

                h2.banner__subtitle (съёмные протезы, протезы на имплантах, коронки из керамики и циркония)
                h2.banner__subtitle.color-accent от стоматологов-ортопедов, которые входят в ТОП-5 лучших стоматологов СПб!

            include ../components/blocks/banner-content

    +comparison('section section-border-block section-mb-72')

    section.info.info--without-border.section.section-mb-72
        div.info__inner.container
            div.info__container
                div.info__block
                    div.icon
                        div.icon__wrapper.flex-center.blue
                            img(src="/icons/info/1.svg")

                    div.info__content.flex.flex-align-center
                        div.info__text-block
                            h2.info__text.text-w500 Протезирование зубов – #[span.text-w700.color-blue это возможность не только красиво улыбаться, но и восстановить утраченное здоровье]! Вновь обрести возможность есть любимую пищу!

                        div.info__img-container.img-container
                            img(src="images/info-img.png" alt="")

                div.info__row.row
                    div.info__col.col-12.mb-col-6
                        div.icon
                            div.icon__wrapper.flex-center.accent
                                img(src="/icons/info/2.svg")

                        div.info__content
                            div.info__text-block.text-center
                                p.info__name.color-blue.text-w700.text-upper СЪЕМНОЕ ПРОТЕЗИРОВАНИЕ
                                p рекомендовано пациентам с полным отсутствием зубов. Акриловые, нейлоновые протезы, протезы Acry Free от наших стоматологов-ортопедов станут удобной заменой собственных зубов и восстановят жевательную и эстетическую функции.

                    div.info__col.col-12.mb-col-6
                        div.icon
                            div.icon__wrapper.flex-center.accent
                                img(src="/icons/info/3.svg")

                        div.info__content
                            div.info__text-block.text-center
                                p.info__name.color-accent.text-w700.text-upper НЕСЪЕМНОЕ ПРОТЕЗИРОВАНИЕ
                                p может проводиться как на собственных зубах (установка коронок, мостовидных протезов из нескольких коронок), так и на имплантах. Мостовидные протезы с опорой на импланты, полное восстановление зубов челюсти на четырёх имплантах, единичные коронки на импланты полностью восстановят зубной ряд и вернут здоровую улыбку!

    +we-care('section-mb-72', '/images/we-care-2.png', false)

    +awards('section section-mb-72', false, true)

    +prices('section section-border-block section-mb-72', 'Виды протезирования и стоимость', dentalProstheticsArr, 'Узнать подробнее', 'text-upper', 'dark', 'section-mb-72')

    +quote('section section-mb-72')

    section.person-list.section.section-border-top
        div.person-list__inner.container
            each item, index in dentalProstheticsPersons
                +person(item, index % 2 === 0)

    +with-love('section section-border-top')

    +with-lowe-2('section-mb-72 section-pb-72 section-border-bottom')

    +counter('section-mb-72')

    +patients-say('section section-border-block')

    +familiar-person('section section-border-bottom')

    +consultation('section', '/images/consultation-team-3.png')

    +welcome('section section-mb-72', false, 'section-mb-72')
