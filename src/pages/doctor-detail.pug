extends ../components/layouts/base.pug

include ../components/common/breadcrumbs
include ../components/common/person
include ../components/common/video-btn
include ../components/common/product-info
include ../components/common/consultation-2

block title
    | Лившиц Татьяна Львовна

block header
    +header(3)

block content
    +breadcrumbs(["Главная", "Врачи", "Лившиц Татьяна Львовна"])

    section.person-list.section-mb-72
        div.person-list__inner.container
            each item, index in doctorDetailPersons
                +person(item, index % 2 === 0, true)

    section.about-doctor.section-border-block.section
        div.about-doctor__inner.container.flex.flex-align-center
            div.about-doctor__video.img-container.video-player.position-relative
                video(src="/videos/video.mp4" playsinline).js-video-player

                +video-btn()

            div.about-doctor__card
               h4.about-doctor__text.text-w500 «Мой успех – это счастливые улыбки моих пациентов. В них воплощена моя любовь к людям, к моей работе. Я постоянно учусь новому в стоматологии. Каждый день, с каждым своим пациентом я выкладываюсь на 100% своих возможностей, знаний, умений и любви».

    section.education.section
        div.education__inner.container
            h1.education__title.section__title Образование

            div.education__slider-container.position-relative
                div.education__slider.swiper.text-center
                    div.swiper-wrapper
                        each item in education
                            div.education__card.swiper-slide.position-relative
                               div.icon
                                   div.icon__wrapper
                                      img(src=item.img alt=item.title)

                               h4.education__name.text-w700= item.title

                               p.education__text= item.text


                button(type="button" aria-label="Предыдущий слайд").education__btn.prev.swiper-arrow
                    include ../components/icons/swiper-arrow
                button(type="button" aria-label="Следующий слайд").education__btn.next.swiper-arrow
                    include ../components/icons/swiper-arrow

    section.certificates.section.section-border-top
        div.certificates__inner.container
            h1.certificates__title.section__title Дополнительное образование и сертификаты

            div.certificates__slider-container.position-relative
                div.certificates__slider.swiper.text-center
                    div.swiper-wrapper
                        each item in certificates
                            div.certificates__card.swiper-slide.position-relative
                                img(src=item alt="")


                button(type="button" aria-label="Предыдущий слайд").certificates__btn.prev.swiper-arrow
                    include ../components/icons/swiper-arrow
                button(type="button" aria-label="Следующий слайд").certificates__btn.next.swiper-arrow
                    include ../components/icons/swiper-arrow

    section.basic-services.section.section-border-block
        div.basic-services__inner.container
            h1.basic-services__title.text-center Основные услуги врача

            div.basic-services__slider-container.position-relative
                div.basic-services__slider.swiper.text-center
                    div.swiper-wrapper
                        each item in basicServices
                            div.basic-services__card.swiper-slide.position-relative
                                div.icon.icon--big
                                    div.icon__wrapper
                                        img(src=item.img alt="")

                                h4.basic-services__name.text-w500= item.title

                                a(href="#").basic-services__link.button.dark.w-100 Подробнее

                button(type="button" aria-label="Предыдущий слайд").basic-services__btn.prev.swiper-arrow
                    include ../components/icons/swiper-arrow
                button(type="button" aria-label="Следующий слайд").basic-services__btn.next.swiper-arrow
                    include ../components/icons/swiper-arrow

    section.doctor-work.section
        div.doctor-work__inner.container
            h1.doctor-work__title.text-center Работы врача

            div.doctor-work__slider-container.position-relative
                div.doctor-work__slider.swiper
                    div.swiper-wrapper
                        each item in Array(3)
                            div.swiper-slide
                                +product-info()


                button(type="button" aria-label="Предыдущий слайд").doctor-work__btn.prev.swiper-arrow
                    include ../components/icons/swiper-arrow
                button(type="button" aria-label="Следующий слайд").doctor-work__btn.next.swiper-arrow
                    include ../components/icons/swiper-arrow

    section.doctor-reviews.section.section-border-block
        div.doctor-reviews__inner.container
            div.doctor-reviews__list.flex
                div.review.position-relative
                    img(src="/images/person-review.png" alt="ПроДокторов" loading="lazy" width="89" height="10").person__review-img.review__img.position-absolute

                    div.review__content
                        div.review__left
                            p.review__name.color-blue.text-w500 Пациент +7 938 12ХХХХХ

                            p.review__date 25 декабря 2022 в 14:30

                            div.review__rating.flex.flex-align-center
                                include ../components/icons/person-star

                                p 5.0

                                span Отлично

                            div.review__security.flex.flex-align-center
                                include ../components/icons/person-security

                                span Отзыв проверен

                        div.review__right
                            div.review__expandable
                                div.review__block
                                    p.review__title.text-w500 История пациента
                                    p.review__message ...Хочется сказать, что Рахманов Михаил Сергеевич – виртуоз своего дела! :) Я осталась под большим впечатлением. Просто руки Бога (побывав в руках двух хирургов ранее, мне есть с чем сравнить).
                                div.review__block
                                    p.review__title.text-w500 Понравилось
                                    p.review__message Михаил Сергеевич работает быстро, аккуратно, профессионально, можно даже сказать нежно.

                                div.review__block.visible-mobile
                                    p.review__title.text-w500 Не понравилось
                                    p.review__message Не может что-то не нравиться, когда все идеально.

                                div.review__last-reception.visible-mobile.flex
                                    img(src="/icons/person-calendar.svg" alt="" loading="lazy" width="16" height="16")

                                    div.review__last-reception__right
                                        p.text-w500 Приём был в декабре 2022
                                        p.text-w500 «Стоматология доктора Лившиц» - ул. Торжковская, д. 13, корп. 1
                            button(type="button").review__more.color-blue.visible-mobile.text-w500 Читать полностью

                div.review.position-relative.hidden-tablet
                    img(src="/images/person-review.png" alt="ПроДокторов" loading="lazy" width="89" height="10").person__review-img.review__img.position-absolute

                    div.review__content
                        div.review__left
                            p.review__name.color-blue.text-w500 Пациент +7 938 12ХХХХХ

                            p.review__date 25 декабря 2022 в 14:30

                            div.review__rating.flex.flex-align-center
                                include ../components/icons/person-star

                                p 5.0

                                span Отлично

                            div.review__security.flex.flex-align-center
                                include ../components/icons/person-security

                                span Отзыв проверен

                        div.review__right
                            div.review__expandable
                                div.review__block
                                    p.review__title.text-w500 История пациента
                                    p.review__message ...Хочется сказать, что Рахманов Михаил Сергеевич – виртуоз своего дела! :) Я осталась под большим впечатлением. Просто руки Бога (побывав в руках двух хирургов ранее, мне есть с чем сравнить).
                                div.review__block
                                    p.review__title.text-w500 Понравилось
                                    p.review__message Михаил Сергеевич работает быстро, аккуратно, профессионально, можно даже сказать нежно.

                                div.review__block.visible-mobile
                                    p.review__title.text-w500 Не понравилось
                                    p.review__message Не может что-то не нравиться, когда все идеально.

                                div.review__last-reception.visible-mobile.flex
                                    img(src="/icons/person-calendar.svg" alt="" loading="lazy" width="16" height="16")

                                    div.review__last-reception__right
                                        p.text-w500 Приём был в декабре 2022
                                        p.text-w500 «Стоматология доктора Лившиц» - ул. Торжковская, д. 13, корп. 1

                            button(type="button").review__more.color-blue.visible-mobile.text-w500 Читать полностью


            a(href="#").doctor-reviews__link.button.dark.m-auto.flex.flex-align-center.text-w600 Посмотреть все на
                img(src="/images/doctor-reviews-img.svg" alt="")

    +consultation-2('section')
