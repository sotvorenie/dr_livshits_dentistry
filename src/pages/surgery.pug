extends ../components/layouts/base.pug

include ../components/common/breadcrumbs
include ../components/blocks/prices
include ../components/blocks/we-care
include ../components/blocks/awards
include ../components/common/person

block title
    | Хирургия

block content
    +breadcrumbs(["Главная", "Услуги", "Хирургия"])

    section.banner.section-mb-72
        div.banner__inner.container
            div.banner__text-block.text-center
                h1.banner__title.color-blue
                    | Бережное удаление зубов
                    br
                    |любой степени сложности

                h2.banner__subtitle с использованием лазера VarioSurg, а так же
                h2.banner__subtitle.color-accent весь спектр операций в области хирургической стоматологии
                h2.banner__subtitle.color-blue от опытных врачей, которые входят в ТОП-5 лучших стоматологов-хирургов СПб!

            include ../components/blocks/banner-content

    include ../components/blocks/comparison

    include ../components/blocks/info

    +prices('Стоимость удаления зубов', surgeryArr, 'Записаться на консультацию', '', 'accent')

    +we-care

    +awards(false)

    include ../components/blocks/quote

    section.person-list.section.section-mb-72.section-border-block
        div.person-list__inner.container
            each item, index in surgeryPersons
                +person(item, index % 2 === 0)

    include ../components/blocks/principles-operation

    include ../components/blocks/proud-reviews

    include ../components/blocks/other-services