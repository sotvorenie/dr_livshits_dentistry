include ../common/header/header
include ../common/footer/footer

doctype html
html(lang="ru")
    head
        meta(charset="utf-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title
            block title
                | Page title
    body
        .video-modal.js-video-modal
            .video-modal__overlay.js-modal-close
            .video-modal__content
                button.video-modal__close.js-modal-close(aria-label="Закрыть" title="Закрыть")
                    include ../icons/header/cross
                video(controls playsinline).video-modal__video.js-modal-video

        block header
            +header

        main
            block content

        block footer
            +footer

        script(type="module" src="/src/scripts/main.js")
